{
  "name": "voice-realtime-sdk-demo",
  "version": "3.0.1",
  "description": "Voice realtime ChatClient: REST (webrtc/v1 start/stop) + Web RTC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "demo",
    "README.md",
    "README.zh-CN.md"
  ],
  "sideEffects": false,
  "keywords": [
    "voice",
    "web-rtc",
    "realtime"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "verify:defaults": "node scripts/verify-defaults.mjs",
    "build": "pnpm run verify:defaults && vite build --config vite.lib.config.js",
    "prepublishOnly": "pnpm run build",
    "demo": "vite --config vite.config.js",
    "demo:build": "vite build --config vite.config.js",
    "demo:preview": "vite preview --config vite.config.js --port 5174"
  },
  "dependencies": {
    "@koi-video/voice-realtime-sdk": "^3.0.1",
    "agora-rtc-sdk-ng": "^4.24.2"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "vite": "^6.0.1"
  }
}
